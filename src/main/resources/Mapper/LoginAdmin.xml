<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.explore.xianhuaback.Mapper.MapperLoginAdmin">

    <select id="getAdminLogin"
            parameterType="com.explore.xianhuaback.Entity.AdminLogin"
            resultType="com.explore.xianhuaback.Entity.AdminLogin">
        SELECT
        id,
        username ,
        password ,
        register_time,
        last_login_time
        FROM AdminLogin
        WHERE username = #{userName}
          AND password = #{passWord}
    </select>

    <select id="getSubmitAdmin"
            parameterType="string"
            resultType="com.explore.xianhuaback.Entity.SubmitAdmin">
            select id,username,password,email,register_time from adminsubmit
            where username=#{userName}
    </select>

    <insert id="insertSubmitAdmin"  parameterType="com.explore.xianhuaback.Entity.SubmitAdmin" >
        insert into AdminSubmit(username,password,email,register_time)
        values (
                #{userName},#{passWord},#{email}, NOW()
               )
    </insert>

    <insert id="insertLoginAdmin"   parameterType="com.explore.xianhuaback.Entity.SubmitAdmin">
            insert into  AdminLogin(username,password, register_time,last_login_time)
            values (
                    #{userName},
                    #{passWord},
                    NOW(),
                    NOW()
                   )

    </insert>

    <update id="PutAdminPassword" parameterType="com.explore.xianhuaback.Entity.editPassword">
        update adminlogin
        SET password = #{passWord}
        WHERE username = #{userName}
    </update>



</mapper>